# Anthropic API Key (shared across all bots)
ANTHROPIC_API_KEY=sk-ant-...

# Bot tokens (create each bot via @BotFather on Telegram)
# Chat IDs (send /start to each bot, then get chat_id via https://api.telegram.org/bot<TOKEN>/getUpdates)

