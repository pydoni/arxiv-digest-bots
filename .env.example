TELEGRAM_CHAT_ID_DATA_SCIENTIST=

TELEGRAM_BOT_TOKEN_GENAI_ENGINEER=
TELEGRAM_CHAT_ID_GENAI_ENGINEER=

TELEGRAM_BOT_TOKEN_CV_ENGINEER=
TELEGRAM_CHAT_ID_CV_ENGINEER=

TELEGRAM_BOT_TOKEN_DATA_ENGINEER=
